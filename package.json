{
  "name": "hook.notifier",
  "version": "2.0.0",
  "description": "Turn any webhook or script into a real push notification on your phone. One HTTP request, no app to build, free with no quota.",
  "homepage": "https://hooknotifier.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lunar-corp/hooknotifier.js.git"
  },
  "license": "MIT",
  "author": "illuday",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "push-notification",
    "notification",
    "webhook",
    "notify",
    "alerts",
    "push",
    "phone",
    "android",
    "ios",
    "typescript"
  ],
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
